-- ============================================
-- MENÜ HAREKET ETTİRME (Sürükle Bırak)
-- Bu kodu scriptinin EN SONUNA yapıştır
-- ============================================

local player = game.Players.LocalPlayer
local mouse = player:GetMouse()

-- Menü çerçevesini bul (mainFrame veya frame adında olabilir)
local frame = nil

-- Ana çerçeveyi ara
if mainFrame then
    frame = mainFrame
elseif frame then
    frame = frame
else
    -- workspace içinde GUI'yi bul
    for _, gui in pairs(game.CoreGui:GetChildren()) do
        if gui:IsA("ScreenGui") then
            for _, child in pairs(gui:GetChildren()) do
                if child:IsA("Frame") and child.Size.X.Offset > 100 then
                    frame = child
                    break
                end
            end
        end
    end
end

if frame then
    local dragging = false
    local dragStart = nil
    local startPos = nil
    
    -- Başlık çubuğunu bul (TitleBar veya başlık içeren frame)
    local titleBar = frame:FindFirstChild("TitleBar") or frame:FindFirstChild("titleBar") or frame:FindFirstChild("Header")
    
    if not titleBar then
        -- Başlık çubuğu yoksa, frame'in içindeki ilk TextLabel'i bul
        for _, child in pairs(frame:GetChildren()) do
            if child:IsA("TextLabel") and child.Text ~= "" then
                titleBar = child
                break
            end
        end
    end
    
    if not titleBar then
        -- Hiçbiri yoksa frame'in kendisini kullan (her yerden sürüklenebilir)
        titleBar = frame
    end
    
    titleBar.BackgroundTransparency = 0.8
    titleBar.BorderSizePixel = 0
    
    -- Sürükleme başlat
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = Vector2.new(mouse.X, mouse.Y)
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    -- Sürükleme sırasında hareket ettir
    mouse.Move:Connect(function()
        if dragging then
            local delta = Vector2.new(mouse.X, mouse.Y) - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    print("✅ Menü hareket ettirilebilir! (Başlık çubuğundan tutup sürükleyin)")
else
    warn("❌ Menü bulunamadı! frame değişkenini kontrol et.")
end
